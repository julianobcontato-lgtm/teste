{
  "entities": {
    "Report": {
      "title": "Urban Maintenance Report",
      "description": "A report submitted by a citizen regarding an urban problem.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Short title of the issue" },
        "description": { "type": "string", "description": "Detailed description of the problem" },
        "category": { 
          "type": "string", 
          "enum": ["pothole", "lighting", "trash", "water", "other"],
          "description": "Type of the issue"
        },
        "status": { 
          "type": "string", 
          "enum": ["pending", "in-progress", "resolved"],
          "description": "Current status of the report"
        },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"]
        },
        "address": { "type": "string", "description": "Manual written address" },
        "imageUrl": { "type": "string", "format": "uri" },
        "managerComment": { "type": "string", "description": "Feedback from editor/admin" },
        "managerPhotoUrl": { "type": "string", "format": "uri" },
        "reporterName": { "type": "string" },
        "actualReporterName": { "type": "string" },
        "userId": { "type": "string" },
        "isAnonymous": { "type": "boolean" },
        "cpf": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "changeRequested": { "type": "boolean" },
        "proposedChanges": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "category": { "type": "string" }
          }
        }
      },
      "required": ["title", "description", "category", "status", "location", "userId", "isAnonymous", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { 
          "type": "string", 
          "enum": ["citizen", "editor", "admin"]
        },
        "cpf": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["displayName", "email", "role"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Public collection of all urban issues."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profile data."
    }
  }
}
